NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/courier-booking
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Email Config
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# SMS Config (Twilio)
SMS_ACCOUNT_SID=your_sid
SMS_AUTH_TOKEN=your_token
SMS_PHONE_NUMBER=your_twilio_number

# Delhivery Config
DELHIVERY_API_KEY=your_delhivery_key
DELHIVERY_BASE_URL=https://api.delhivery.com/

# Maps Config
GOOGLE_MAPS_API_KEY=your_key

# Frontend Config
CORS_ORIGIN=http://localhost:5173
